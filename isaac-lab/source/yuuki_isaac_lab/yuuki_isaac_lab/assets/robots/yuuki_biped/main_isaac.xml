<mujoco model="yuuki_robot_biped_isaac">
  <!--
    Isaac Lab / PhysX 用 MJCF（MuJoCo 用 main.xml から派生）。

    変更点:
    - worldbody の床・カメラ・ライトを除去（Isaac Lab 側で GroundPlane / DomeLight を配置）
    - basket_thigh の body pos を (0,0,0) に変更
      → 立位高さ 0.66 m は ArticulationCfg.init_state.pos で一元管理（二重オフセット防止）

  ロボット形状・関節・actuator は main.xml と同一。
  -->

  <default>
    <site size="0.02" rgba="1 1 0 1"/>
    <joint damping="1.5" armature="0.02"/>
    <geom friction="1.15 0.005 0.0001"/>
  </default>

  <visual>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <asset>
    <material name="basket" rgba="0.85 0.82 0.7 1"/>
    <material name="servo" rgba="0.65 0.1 0.18 1"/>
    <material name="metal" rgba="0.7 0.7 0.7 1"/>
    <material name="lipo" rgba="0.95 0.55 0.1 0.85"/>
  </asset>

  <worldbody>
    <!-- ルート原点 = カゴ底面中央。高さは Isaac Lab init_state.pos.z で指定 -->
    <body name="basket_thigh" pos="0 0 0">
      <freejoint name="root"/>
      <site name="imu_site" pos="0 0 0.05"/>

      <geom name="basket" type="box" pos="0 0 0.0725" size="0.09 0.14 0.0725" material="basket" mass="0.5"/>

      <body name="basket_top_roll" pos="0 0 0.145">
        <joint name="basket_top_roll" type="hinge" axis="1 0 0" range="-45 45" damping="2"/>
        <inertial pos="0 0 0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
        <geom name="basket_top_roll_servo" type="box" pos="0 0 0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

        <body name="balance_pitch" pos="0 0 0.065">
          <joint name="balance_pitch" type="hinge" axis="0 1 0" range="-45 45" damping="2"/>
          <inertial pos="0 0 0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
          <geom name="balance_pitch_servo" type="box" pos="0 0 0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

          <body name="balance_bar" pos="0 0 0.065">
            <geom name="balance_bar" type="box" pos="0 0 0.125" size="0.015 0.015 0.125" material="metal" mass="1.5"/>
          </body>
        </body>
      </body>

      <body name="left_hip" pos="0 0.12 0">
        <joint name="left_hip_roll" type="hinge" axis="1 0 0" range="-30 90" damping="2"/>
        <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
        <geom name="left_hip_roll_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

        <body name="left_thigh" pos="0 0 -0.065">
          <joint name="left_hip_pitch" type="hinge" axis="0 1 0" range="-110 30" damping="2"/>
          <geom name="left_thigh_plate_outer" type="box" pos="0 0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
          <geom name="thigh_link" type="box" pos="0 -0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
          <geom name="left_thigh_lipo" type="box" pos="0 0 -0.10" size="0.012 0.02 0.065" material="lipo" mass="0.302" contype="0" conaffinity="0"/>

          <body name="left_knee" pos="0 0 -0.20">
            <joint name="left_knee_pitch" type="hinge" axis="0 1 0" range="0 100" damping="2"/>
            <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
            <geom name="left_knee_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

            <body name="left_shin" pos="0 0 -0.065">
              <geom name="left_shin_plate_outer" type="box" pos="0 0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
              <geom name="shank_link" type="box" pos="0 -0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
              <geom name="left_shin_lipo" type="box" pos="0 0 -0.10" size="0.012 0.02 0.065" material="lipo" mass="0.302" contype="0" conaffinity="0"/>

              <body name="left_ankle_pitch" pos="0 0 -0.20">
                <joint name="left_ankle_pitch" type="hinge" axis="0 1 0" range="-20 90" damping="2"/>
                <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
                <geom name="left_ankle_pitch_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

                <body name="left_ankle_roll" pos="0 0 -0.065">
                  <joint name="left_ankle_roll" type="hinge" axis="1 0 0" range="-20 20" damping="2"/>
                  <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
                  <geom name="left_ankle_roll_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

                  <body name="left_sole" pos="0 0 -0.065">
                    <site name="foot_site" pos="0.10 0 0.001"/>
                    <site name="heel_bottom_site" pos="-0.025 0 0"/>
                    <site name="toe_bottom_site" pos="0.205 0 0"/>
                    <geom name="foot_plate" type="box" pos="0.10 0 0.001" size="0.125 0.05 0.001" material="metal" mass="0.226"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <body name="right_hip" pos="0 -0.12 0">
        <joint name="right_hip_roll" type="hinge" axis="1 0 0" range="-30 90" damping="2"/>
        <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
        <geom name="right_hip_roll_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

        <body name="right_thigh" pos="0 0 -0.065">
          <joint name="right_hip_pitch" type="hinge" axis="0 1 0" range="-110 30" damping="2"/>
          <geom name="right_thigh_plate_outer" type="box" pos="0 -0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
          <geom name="right_thigh_link" type="box" pos="0 0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
          <geom name="right_thigh_lipo" type="box" pos="0 0 -0.10" size="0.012 0.02 0.065" material="lipo" mass="0.302" contype="0" conaffinity="0"/>

          <body name="right_knee" pos="0 0 -0.20">
            <joint name="right_knee_pitch" type="hinge" axis="0 1 0" range="0 100" damping="2"/>
            <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
            <geom name="right_knee_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

            <body name="right_shin" pos="0 0 -0.065">
              <geom name="right_shin_plate_outer" type="box" pos="0 -0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
              <geom name="right_shin_link" type="box" pos="0 0.0255 -0.10" size="0.02 0.0015 0.10" material="metal" mass="0.063"/>
              <geom name="right_shin_lipo" type="box" pos="0 0 -0.10" size="0.012 0.02 0.065" material="lipo" mass="0.302" contype="0" conaffinity="0"/>

              <body name="right_ankle_pitch" pos="0 0 -0.20">
                <joint name="right_ankle_pitch" type="hinge" axis="0 1 0" range="-20 90" damping="2"/>
                <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
                <geom name="right_ankle_pitch_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

                <body name="right_ankle_roll" pos="0 0 -0.065">
                  <joint name="right_ankle_roll" type="hinge" axis="1 0 0" range="-20 20" damping="2"/>
                  <inertial pos="0 0 -0.0325" mass="0.18" diaginertia="0.00012 0.00012 0.00012"/>
                  <geom name="right_ankle_roll_servo" type="box" pos="0 0 -0.0325" size="0.015 0.024 0.0325" material="servo" mass="0" contype="0" conaffinity="0"/>

                  <body name="right_sole" pos="0 0 -0.065">
                    <site name="right_foot_site" pos="0.10 0 0.001"/>
                    <site name="right_heel_bottom_site" pos="-0.025 0 0"/>
                    <site name="right_toe_bottom_site" pos="0.205 0 0"/>
                    <geom name="right_foot_plate" type="box" pos="0.10 0 0.001" size="0.125 0.05 0.001" material="metal" mass="0.226"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="left_hip_roll_motor" joint="left_hip_roll" kp="85" kv="12" ctrlrange="-0.524 1.571" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="left_hip_pitch_motor" joint="left_hip_pitch" kp="85" kv="12" ctrlrange="-1.919 0.524" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="left_knee_pitch_motor" joint="left_knee_pitch" kp="120" kv="14" ctrlrange="0 1.745" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="left_ankle_pitch_motor" joint="left_ankle_pitch" kp="70" kv="10" ctrlrange="-0.349 1.571" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="left_ankle_roll_motor" joint="left_ankle_roll" kp="50" kv="8" ctrlrange="-0.349 0.349" forcelimited="true" forcerange="-14.7 14.7"/>

    <position name="right_hip_roll_motor" joint="right_hip_roll" kp="85" kv="12" ctrlrange="-0.524 1.571" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="right_hip_pitch_motor" joint="right_hip_pitch" kp="85" kv="12" ctrlrange="-1.919 0.524" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="right_knee_pitch_motor" joint="right_knee_pitch" kp="120" kv="14" ctrlrange="0 1.745" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="right_ankle_pitch_motor" joint="right_ankle_pitch" kp="70" kv="10" ctrlrange="-0.349 1.571" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="right_ankle_roll_motor" joint="right_ankle_roll" kp="50" kv="8" ctrlrange="-0.349 0.349" forcelimited="true" forcerange="-14.7 14.7"/>

    <position name="basket_top_roll_motor" joint="basket_top_roll" kp="85" kv="12" ctrlrange="-0.785 0.785" forcelimited="true" forcerange="-14.7 14.7"/>
    <position name="balance_pitch_motor" joint="balance_pitch" kp="85" kv="12" ctrlrange="-0.785 0.785" forcelimited="true" forcerange="-14.7 14.7"/>
  </actuator>

  <sensor>
    <gyro name="imu_gyro" site="imu_site"/>
    <framezaxis name="imu_zaxis" objtype="site" objname="imu_site"/>
    <framexaxis name="foot_xaxis" objtype="site" objname="foot_site"/>
    <framezaxis name="foot_zaxis" objtype="site" objname="foot_site"/>
    <framepos name="toe_pos" objtype="site" objname="toe_bottom_site"/>
  </sensor>
</mujoco>
