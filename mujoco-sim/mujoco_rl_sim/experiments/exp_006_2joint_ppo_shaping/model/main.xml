<mujoco model="yuuki_robot_1joint">
  <!-- 
    以下のオプションは、親子の(bodyの)geomが接触しないようにXMLを変更したためコメントアウトした。
    有効にすると、親子の(bodyの)geomが接触するようになる。
  -->
  <!-- <option>
    <flag filterparent="disable"/>
  </option> -->

  <default>
    <site size="0.03" rgba="1 1 0 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2=".6 .8 1" width="256" height="256"/>
    <!-- <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3" /> -->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".3 .1 .1" rgb2=".1 .1 .3" />
    <material name="floor_mat" texture="grid" texrepeat="40 40"/>
    <material name="basket" rgba="0.85 0.82 0.7 1"/>
    <material name="servo" rgba="0.65 0.1 0.18 1"/>
    <material name="metal" rgba="0.7 0.7 0.7 1"/>
  </asset>

  <worldbody>
    <camera pos="0 -1 1" xyaxes="0 1 0 0 0 1"/>
    <light pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" type="plane" size="25 25 0.1" material="floor_mat"/>

    <!-- 基準はカゴの底中央としている。 -->
    <body name="basket_thigh" pos="0 0 0.9">
      <freejoint name="root"/>

      <!-- <site name="imu_site" pos="0 0 0.05" euler="0 0 -90"/> -->
      <site name="imu_site" pos="0 0 0.05"/>

      <geom name="basket" type="box" pos="0 0 0.0725" size="0.09 0.14 0.0725" material="basket" mass="0.3"/>

      <!--
        【大腿リンク】
        docs/human_anthropometry.mdを参考に170cm / 70kgの男性の例の下限値を採用した。
        大腿の長さは 41 cm
        大腿の質量は 9.9 kg
      -->
      <geom name="thigh_link" type="box" pos="0 0 -0.205" size="0.02 0.04 0.205" material="metal" mass="9.9"/>

      <body name="shank" pos="0 0 -0.43">
        <!--
          膝関節は人間と同様に、真下を0°として、後ろに100°まで曲げられるようにする。
          人間と同様、前には曲げられないようにする。
        -->
        <joint name="knee" type="hinge" axis="0 1 0" range="0 100"/>

        <!--
          【下腿リンク】
          docs/human_anthropometry.mdを参考に170cm / 70kgの男性の例の下限値を採用した。
          下腿の長さは 41 cm
          下腿の質量は 3.0 kg
        -->
        <geom name="shank_link" type="box" pos="0 0 -0.205" size="0.02 0.04 0.205" material="metal" mass="3.0"/>

        <body name="foot" pos="0 0 -0.46">
          <!--
            踵関節は人間と同様に、真横を0°として、つま先を上に持ち上げる方向に20°まで、
            地面を蹴る方向に90°まで曲げられるようにする。
          -->
          <joint name="ankle" type="hinge" axis="0 1 0" range="-20 90"/>

          <!-- foot_site: 足底板 geom 中心（foot_z 用） -->
          <site name="foot_site" pos="0.1 0 0"/>
          <!-- foot_plate pos=0.1 size x=0.12 z=0.01 → 底面 z=-0.01、X 端は -0.02 / 0.22 -->
          <site name="heel_bottom_site" pos="-0.02 0 -0.01"/>
          <site name="toe_bottom_site" pos="0.22 0 -0.01"/>

          <!--
            【足底板】
            docs/human_anthropometry.mdを参考に170cm / 70kgの男性の例の下限値を採用した。
            足底板の長さは 24 cm
            足底板の幅は 8 cm
            足底板の質量は 1.0 kg
          -->
          <geom name="foot_plate" type="box" pos="0.1 0 0" size="0.12 0.04 0.01" material="metal" mass="1.0"/>
        </body>
      </body>

      <!-- 1 Leg -->
      <!-- <body name="leg" pos="0 0 0">
        <joint name="hip" type="hinge" axis="0 1 0"/>

        <site name="leg_site" pos="0 0 -0.45"/>

        <geom name="leg_link" type="box" pos="0 0 -0.45" size="0.02 0.04 0.35" material="metal" mass="1"/>
        <geom name="foot_plate" type="box" pos="0.1 0 -0.8" size="0.15 0.085 0.03" material="metal" mass="0.5"/>
      </body> -->
    </body>
  </worldbody>

  <actuator>
    <!--
      膝関節は人間と同様、真下を0°(0 rad)として、後ろに100°(1.745 rad)まで曲げられるようにする。
      指定できるctrlrangeも、それに従い0~1.745 radにする。
      また、膝関節のトルクは docs/human_joint_torque.md を参考に体重70kgの例の下限値を採用する。
      膝を伸ばす方向(ctrlマイナス方向)のトルク（膝伸展）は168 N・m
      膝を曲げる方向(ctrlプラス方向)のトルク（膝屈曲）は70 N・m
    -->
    <position
      name="knee_servo" 
      joint="knee" 
      kp="300" 
      kv="1" 
      ctrlrange="0 1.745" 
      forcerange="-168 70"
      forcelimited="true"
    />

    <!--
      踵関節は人間と同様に、真横を0°として、つま先を上に持ち上げる方向に20°まで、
      地面を蹴る方向に90°まで曲げられるようにする。
      指定できるctrlrangeも、それに従い-0.349 rad～1.571 radにする。
      また、踵関節のトルクは docs/human_joint_torque.md を参考に体重70kgの例の下限値を採用する。
      踵を地面を蹴る方向(ctrlプラス方向)のトルク（足関節底屈）は98 N・m
      踵をつま先を上げる方向(ctrlマイナス方向)のトルク（足関節背屈）は21 N・m
    -->
    <position
      name="ankle_servo" 
      joint="ankle" 
      kp="300" 
      kv="1" 
      ctrlrange="-0.349 1.571" 
      forcerange="-21 98"
      forcelimited="true"
    />
  </actuator>

  <sensor>
    <gyro name="imu_gyro" site="imu_site"/>

    <!-- <accelerometer name="imu_acc" site="imu_site"/> -->

    <!-- <framepos name="imu_pos" objtype="site" objname="imu_site"/> -->
    <framezaxis name="imu_zaxis" objtype="site" objname="imu_site"/>

    <framexaxis name="foot_xaxis" objtype="site" objname="foot_site"/>
    <framezaxis name="foot_zaxis" objtype="site" objname="foot_site"/>

    <framepos name="toe_pos" objtype="site" objname="toe_bottom_site"/>

    <!-- <framequat name="leg_quat" objtype="site" objname="leg_site"/> -->
  </sensor>
</mujoco>