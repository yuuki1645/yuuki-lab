<worldbody>
  <camera pos="0 -1 1" xyaxes="0 1 0 0 0 1"/>
  <light pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
  <geom type="plane" size="5 5 0.1" material="floor_mat"/>

  <!-- 基準はカゴの底中央としている。001_leg_default との差は root の freejoint の有無。 -->
  <body pos="0 0 0.9">
    <freejoint name="root"/>

    <site name="imu_site" pos="0 0 0" euler="0 0 -90" size="0.01" rgba="1 0 0 1"/>

    <geom name="basket" type="box" pos="0 0 0.07" size="0.085 0.14 0.07" material="basket" mass="0.3"/>

    <!-- Left leg -->
    <body name="left_hip" pos="0 0.11 0">
      <joint name="left_hip_roll" type="hinge" axis="1 0 0" range="-30 90" damping="2"/>
      <geom
        name="left_hip_servo" type="box" pos="0 0 -0.0325"
        size="0.015 0.025 0.0325" material="servo" mass="0.162"
        contype="0" conaffinity="0"
      />

      <body name="left_thigh" pos="0 0 -0.1">
        <joint
          name="left_hip_pitch" type="hinge" axis="0 1 0"
          range="-120 30" damping="2"
        />
        <geom name="left_thigh_link" type="box" pos="0 0 -0.1" size="0.04 0.025 0.1" material="metal" mass="0.5" />

        <body name="left_shin" pos="0 0 -0.2">
          <joint name="left_knee_pitch" type="hinge" axis="0 1 0" damping="2"/>
          <geom name="left_shin_link" type="box" pos="0 0 -0.2" size="0.04 0.025 0.1" material="metal" mass="0.5" />

          <body name="left_ankle" pos="0 0 -0.30">
            <joint name="left_ankle_pitch" type="hinge" axis="0 1 0" damping="2"/>
            <geom name="left_ankle_servo" type="box" size="0.045 0.035 0.035" material="servo" mass="0.25"/>

            <body name="left_foot" pos="0.05 0 -0.06">
              <joint name="left_ankle_roll" type="hinge" axis="1 0 0" damping="2"/>
              <!-- Large aluminum foot plate approximation -->
              <geom name="left_foot_plate" type="box" size="0.16 0.09 0.01" pos="0.06 0 -0.015" material="metal" mass="0.8" friction="1.5 0.02 0.001"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Right leg -->
    <body name="right_hip" pos="0 -0.11 0">
      <joint name="right_hip_roll" type="hinge" axis="1 0 0" damping="2"/>
      <geom
        name="right_hip_servo" type="box" pos="0 0 -0.0325" size="0.015 0.025 0.0325"
        material="servo" mass="0.162"
        contype="0" conaffinity="0"
      />

      <body name="right_thigh" pos="0 0 -0.1">
        <joint name="right_hip_pitch" type="hinge" axis="0 1 0" damping="2"/>
        <geom name="right_thigh_link" type="box" pos="0 0 -0.1" size="0.04 0.025 0.1" material="metal" mass="0.5" />

        <body name="right_shin" pos="0 0 -0.2">
          <joint name="right_knee_pitch" type="hinge" axis="0 1 0" damping="2"/>
          <geom name="right_shin_link" type="box" pos="0 0 -0.2" size="0.04 0.025 0.1" material="metal" mass="0.5" />

          <body name="right_ankle" pos="0 0 -0.30">
            <joint name="right_ankle_pitch" type="hinge" axis="0 1 0" damping="2"/>
            <geom name="right_ankle_servo" type="box" size="0.045 0.035 0.035" material="servo" mass="0.25"/>

            <body name="right_foot" pos="0.05 0 -0.06">
              <joint name="right_ankle_roll" type="hinge" axis="1 0 0" damping="2"/>
              <!-- Large aluminum foot plate approximation -->
              <geom name="right_foot_plate" type="box" size="0.16 0.09 0.01" pos="0.06 0 -0.015" material="metal" mass="0.8" friction="1.5 0.02 0.001"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </body>
</worldbody>
