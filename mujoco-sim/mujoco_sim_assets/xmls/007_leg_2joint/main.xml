<mujoco model="yuuki_robot_1joint">
  <option>
    <flag filterparent="disable"/>
  </option>

  <default>
    <site size="0.03" rgba="1 1 0 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2=".6 .8 1" width="256" height="256"/>
    <!-- <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.2 0.2 0.2" rgb2="0.3 0.3 0.3" /> -->
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".3 .1 .1" rgb2=".1 .1 .3" />
    <material name="floor_mat" texture="grid" texrepeat="8 8"/>
    <material name="basket" rgba="0.85 0.82 0.7 1"/>
    <material name="servo" rgba="0.65 0.1 0.18 1"/>
    <material name="metal" rgba="0.7 0.7 0.7 1"/>
  </asset>

  <worldbody>
    <camera pos="0 -1 1" xyaxes="0 1 0 0 0 1"/>
    <light pos="0 0 10" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="5 5 0.1" material="floor_mat"/>

    <!-- 基準はカゴの底中央としている。 -->
    <body name="basket_thigh" pos="0 0 0.9">
      <freejoint name="root"/>

      <site name="imu_site" pos="0 0 0.05" euler="0 0 -90"/>

      <geom name="basket" type="box" pos="0 0 0.0725" size="0.09 0.14 0.0725" material="basket" mass="0.3"/>
      <geom name="thigh_link" type="box" pos="0 0 -0.2" size="0.02 0.04 0.2" material="metal" mass="0.8"/>

      <body name="shank" pos="0 0 -0.43">
        <joint name="knee" type="hinge" axis="0 1 0"/>

        <geom name="shank_link" type="box" pos="0 0 -0.23" size="0.02 0.04 0.2" material="metal" mass="0.8"/>

        <body name="foot" pos="0 0 -0.46">
          <joint name="ankle" type="hinge" axis="0 1 0"/>

          <site name="foot_site" pos="0.1 0 0"/>

          <geom name="foot_plate" type="box" pos="0.1 0 0" size="0.15 0.085 0.01" material="metal" mass="0.271"/>
        </body>
      </body>

      <!-- 1 Leg -->
      <!-- <body name="leg" pos="0 0 0">
        <joint name="hip" type="hinge" axis="0 1 0"/>

        <site name="leg_site" pos="0 0 -0.45"/>

        <geom name="leg_link" type="box" pos="0 0 -0.45" size="0.02 0.04 0.35" material="metal" mass="1"/>
        <geom name="foot_plate" type="box" pos="0.1 0 -0.8" size="0.15 0.085 0.03" material="metal" mass="0.5"/>
      </body> -->
    </body>
  </worldbody>

  <actuator>
    <position name="knee_servo" joint="knee" kp="300" kv="1" ctrlrange="-1.571 1.571" forcerange="-14.7 14.7"/>
    <position name="ankle_servo" joint="ankle" kp="300" kv="1" ctrlrange="-1.571 1.571" forcerange="-14.7 14.7"/>
  </actuator>

  <sensor>
    <!-- <gyro name="imu_gyro" site="imu_site"/> -->
    <!-- <accelerometer name="imu_acc" site="imu_site"/> -->

    <!-- <framepos name="imu_pos" objtype="site" objname="imu_site"/> -->
    <framezaxis name="imu_zaxis" objtype="site" objname="imu_site"/>
    <framezaxis name="foot_zaxis" objtype="site" objname="foot_site"/>

    <!-- <framequat name="leg_quat" objtype="site" objname="leg_site"/> -->
  </sensor>
</mujoco>